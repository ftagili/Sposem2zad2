int FilterIntFieldProc(int params);
int FilterTextFieldProc(int params);
int JoinTypesVedomostiProc(int params);
int JoinPeopleStudiesStudentsProc(int params);
int UniqueBirthdaysProc(int params);
int PatronymicCountProc(int params);
int GroupAgeProc(int params);
int EnrollmentListProc(int params);
int ExcellentCountProc(int params);
int Group2011Proc(int params);
int NonStudentsProc(int params);
int ResultsSinkProc(int params);

int Run48_1() {
    Pipe rawTypesPipe = openTypesCsvPipe();
    Pipe rawVedomostiPipe = openVedomostiCsvPipe();
    Pipe parsedTypesPipe = createPipe();
    Pipe parsedVedomostiPipe = createPipe();
    Pipe filteredTypesPipe = createPipe();
    Pipe filteredVedomostiPipe = createPipe();
    Pipe joinedPipe = createPipe();
    Pipe resultsPipe = open48_1ResultPipe();

    Stream rawTypesInput = getInputStream(rawTypesPipe);
    Stream rawVedomostiInput = getInputStream(rawVedomostiPipe);
    Stream parsedTypesOutput = getOutputStream(parsedTypesPipe);
    Stream parsedVedomostiOutput = getOutputStream(parsedVedomostiPipe);
    Stream parsedTypesInput = getInputStream(parsedTypesPipe);
    Stream parsedVedomostiInput = getInputStream(parsedVedomostiPipe);
    Stream filteredTypesOutput = getOutputStream(filteredTypesPipe);
    Stream filteredVedomostiOutput = getOutputStream(filteredVedomostiPipe);
    Stream filteredTypesInput = getInputStream(filteredTypesPipe);
    Stream filteredVedomostiInput = getInputStream(filteredVedomostiPipe);
    Stream joinedOutput = getOutputStream(joinedPipe);
    Stream joinedInput = getInputStream(joinedPipe);
    Stream resultsOutput = getOutputStream(resultsPipe);

    int srcTypesParams = makeSourceParams(rawTypesInput, parsedTypesOutput, false);
    int srcVedomostiParams = makeSourceParams(rawVedomostiInput, parsedVedomostiOutput, false);
    int filterTypesParams = make48_1_types_filter_params(parsedTypesInput, filteredTypesOutput);
    int filterVedomostiParams =
        make48_1_veds_filter_params(parsedVedomostiInput, filteredVedomostiOutput);
    int joinParams = make48_1_join_params(filteredTypesInput, filteredVedomostiInput, joinedOutput);
    int sinkParams = makeSinkParams(joinedInput, resultsOutput, false);

    createThread(CsvSourceProc, srcTypesParams);
    createThread(CsvSourceProc, srcVedomostiParams);
    createThread(FilterIntFieldProc, filterTypesParams);
    createThread(FilterIntFieldProc, filterVedomostiParams);
    createThread(JoinTypesVedomostiProc, joinParams);
    createThread(ResultsSinkProc, sinkParams);

    return waitAllThreads();
}

