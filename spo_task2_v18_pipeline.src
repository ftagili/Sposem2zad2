int makeSourceParams(Stream input, Stream output, bool nonblock);
int makeSinkParams(Stream input, Stream output, bool nonblock);
int makeSingleInputParams(Stream input, Stream output, bool nonblock);
int makeTwoInputParams(Stream leftInput, Stream rightInput, Stream output, bool nonblock);

int make48_1_types_filter_params(Stream input, Stream output);
int make48_1_veds_filter_params(Stream input, Stream output);
